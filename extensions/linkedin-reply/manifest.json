{
  "manifest_version": 3,
  "name": "0n LinkedIn — AI Reply Generator",
  "version": "1.0.0",
  "description": "AI-powered LinkedIn engagement. Generate killer replies, find trending posts, and manage service requests — all from one panel.",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.linkedin.com/*", "https://api.groq.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [{
    "matches": ["https://www.linkedin.com/*"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "background": {
    "service_worker": "background.js"
  }
}
